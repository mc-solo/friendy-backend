{
    "info": {
        "_postman_id": "friendy-backend-v1-api-collection",
        "name": "friendy backend API",
        "description": "API collection for friendy. Includes System Health, Auth, Chat, ...and future endpoints under api/v1",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8080",
            "type": "string"
        }
