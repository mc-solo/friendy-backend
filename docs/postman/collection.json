                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"supersecret\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/v1/auth/register",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "v1", "auth", "register"]
                        },
                        "description": "Register a new user account. Returns the created user's ID and email. Returns 409 if the email is already registered."
                    },
                    "response": [
